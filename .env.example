# ============================================================
# Veřejné URL webu (bez koncového lomítka)
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Cloudinary
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Volitelně vlastní upload preset (signed) – jinak se používá default podepisování
CLOUDINARY_UPLOAD_FOLDER=esterky/photos

# DŮLEŽITÉ: stejná hodnota jako CLOUDINARY_CLOUD_NAME.
# Bez této proměnné se obrázky na klientu nezobrazí (bundler ji inlinuje do JS).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ============================================================
# Resend (transakční e-mail)
# ============================================================
RESEND_API_KEY=
# Ověřená odesílací adresa (musí být na doméně ověřené v Resend)
RESEND_FROM="Esterky Fotky <kontakt@domena.cz>"
# Osobní e-mail, kam mají chodit zprávy z kontaktního formuláře
CONTACT_DELIVERY_EMAIL=osobni@email.cz

# ============================================================
# Cloudflare Turnstile
# ============================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================
# Cloudflare Web Analytics (volitelné)
# ============================================================
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ============================================================
# Admin / interní
# ============================================================
# Pokud chceš dodatečnou ochranu přístupu k /studio/login přes known-hosts, přidej si vlastní guard.
